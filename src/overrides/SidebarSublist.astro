---
import type { StarlightRouteData } from '@astrojs/starlight/route-data'

interface Props {
  sublist: StarlightRouteData['sidebar']
  nested?: boolean
  typeMap?: Map<string, 'book' | 'video' | 'course' | 'article'>
}

const { sublist, nested, typeMap } = Astro.props

const icons = {
  book: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
    <path fill="#F59E0B" d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
    <path fill="#FDE68A" d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20v2.5H6.5A2.5 2.5 0 0 1 4 19.5z"/>
    <line x1="9" y1="7" x2="16" y2="7" stroke="#92400E" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="9" y1="10.5" x2="16" y2="10.5" stroke="#92400E" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="9" y1="14" x2="13" y2="14" stroke="#92400E" stroke-width="1.5" stroke-linecap="round"/>
  </svg>`,
  video: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
    <rect x="1" y="5" width="15" height="14" rx="2" fill="#EF4444"/>
    <polygon points="23,7 16,12 23,17" fill="#FCA5A5"/>
    <polygon points="7,9 7,15 12,12" fill="#FEE2E2"/>
  </svg>`,
  course: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
    <polygon points="12,3 22,8 12,13 2,8" fill="#6366F1"/>
    <path d="M6 10.5v5c0 2 2.7 3.5 6 3.5s6-1.5 6-3.5v-5" fill="#A5B4FC"/>
    <line x1="22" y1="8" x2="22" y2="15" stroke="#6366F1" stroke-width="2" stroke-linecap="round"/>
    <circle cx="22" cy="15.5" r="1.5" fill="#6366F1"/>
  </svg>`,
  article: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
    <path fill="#10B981" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
    <path fill="#6EE7B7" d="M14 2l6 6h-6z"/>
    <line x1="8" y1="13" x2="16" y2="13" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="8" y1="17" x2="16" y2="17" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="8" y1="10" x2="11" y2="10" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/>
  </svg>`,
}
---

{
  sublist.map((entry) =>
    entry.type === 'link' ? (
      <a
        href={entry.href}
        aria-current={entry.isCurrent && 'page'}
        class:list={['entry-link', entry.attrs.class]}
        {...entry.attrs}
      >
        {typeMap?.has(entry.href) && (
          <span class="entry-icon" set:html={icons[typeMap.get(entry.href)!]} />
        )}
        {entry.label}
        {entry.badge && <span class="entry-badge">{entry.badge.text}</span>}
      </a>
    ) : (
      <div class="container-sidebar-entry">
        <button class="entry-title-button" data-group-toggle type="button">
          <h4 class="entry-title">{entry.label}</h4>
          <svg
            class="collapse-icon"
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="m6 9 6 6 6-6" />
          </svg>
        </button>
        <div class="container-group-link" data-group-content>
          <Astro.self sublist={entry.entries} nested typeMap={typeMap} />
        </div>
      </div>
    ),
  )
}

<style>
  .container-sidebar-entry {
    flex-direction: column;
    display: flex;
  }

  .container-sidebar-entry.is-expanded {
    margin-bottom: 1rem;
  }

  .entry-title-button {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: none;
    border: none;
    padding: 0.5rem 0;
    cursor: pointer;
    color: inherit;
    font: inherit;
    text-align: left;
  }

  .entry-title-button:hover {
    color: var(--accent-foreground);
  }

  .entry-title {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .entry-link {
    display: flex;
    align-items: flex-start;
    gap: 0.375rem;
  }

  .entry-icon {
    display: inline-flex;
    flex-shrink: 0;
    margin-top: 0.3em;
  }

  .collapse-icon {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s ease-in-out;
    flex-shrink: 0;
  }

  .container-sidebar-entry.collapsed .collapse-icon {
    transform: rotate(-90deg);
  }

  .container-group-link {
    overflow: hidden;
    max-height: 9999px;
    opacity: 1;
  }

  .container-sidebar-entry.collapsed .container-group-link {
    max-height: 0;
    opacity: 0;
    pointer-events: none;
  }
</style>

<script>
  function initSidebar() {
    const buttons = document.querySelectorAll<HTMLElement>('[data-group-toggle]')
    console.log('[sidebar] initSidebar called, buttons found:', buttons.length)
    buttons.forEach((button, idx) => {
      // The button is always the direct first child of .container-sidebar-entry,
      // so parentElement is unambiguous and avoids closest() traversal issues
      const entry = button.parentElement
      if (!entry) return

      const titleText = button.querySelector('.entry-title')?.textContent?.trim()
      console.log(`[sidebar] button[${idx}] "${titleText}", parent class="${entry.className}", parent tag="${entry.tagName}"`)

      // Restore collapse state from localStorage
      if (titleText) {
        const isCollapsed = localStorage.getItem(`sidebar-${titleText}`) === 'true'
        if (isCollapsed) {
          entry.classList.add('collapsed')
          entry.classList.remove('is-expanded')
        } else {
          entry.classList.remove('collapsed')
          entry.classList.add('is-expanded')
        }
      }

      // Attach click handler directly to the button — guard against double
      // registration when astro:page-load re-runs on the same DOM nodes
      if (button.dataset.sidebarInit) {
        console.log(`[sidebar] button[${idx}] "${titleText}" already initialized, skipping`)
        return
      }
      button.dataset.sidebarInit = 'true'

      button.addEventListener('click', () => {
        console.log(`[sidebar] click on "${titleText}", entry classes BEFORE:`, [...entry.classList])
        entry.classList.toggle('collapsed')
        entry.classList.toggle('is-expanded')
        console.log(`[sidebar] click on "${titleText}", entry classes AFTER:`, [...entry.classList])

        if (titleText) {
          localStorage.setItem(`sidebar-${titleText}`, entry.classList.contains('collapsed').toString())
        }
      })
    })
  }

  // Capture-phase: log what ACTUALLY gets clicked (runs before any handler)
  document.addEventListener('click', (e) => {
    const t = e.target as Element
    console.log('[capture-click] tag:', t.tagName, 'class:', t.className.toString().substring(0,60), 'href:', (t as HTMLAnchorElement).href || 'none')
  }, true)

  // DOMContentLoaded — fires on every full page load (no View Transitions)
  document.addEventListener('DOMContentLoaded', initSidebar)
  // astro:page-load — fires after each View Transition navigation (future-proof)
  document.addEventListener('astro:page-load', initSidebar)
</script>
